generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role
  status         Status          @default(ACTIVE)
  createdAt      DateTime        @default(now())
  communityPosts CommunityPost[]
  orders         Order[]
  vendorProfile  VendorProfile?
}

model VendorProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  farmName            String
  certificationStatus String
  farmLocation        String
  orders              Order[]
  products            Product[]
  rentalSpaces        RentalSpace[]
  sustainabilityCerts SustainabilityCert[]
  user                User                 @relation(fields: [userId], references: [id])
}

model Product {
  id                  String        @id @default(uuid())
  vendorId            String
  name                String
  description         String
  price               Float
  category            String
  certificationStatus String
  availableQuantity   Int
  orders              Order[]
  vendor              VendorProfile @relation(fields: [vendorId], references: [id])
}

model RentalSpace {
  id           String        @id @default(uuid())
  vendorId     String
  location     String
  size         Int
  price        Float
  availability Boolean
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
}

model Order {
  id        String        @id @default(uuid())
  userid    String
  produceId String
  vendorId  String
  status    String
  orderDate DateTime      @default(now())
  product   Product       @relation(fields: [produceId], references: [id])
  user      User          @relation(fields: [userid], references: [id])
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  postContent String
  postDate    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model SustainabilityCert {
  id                String        @id @default(uuid())
  vendorId          String
  certifyingAgency  String
  certificationDate DateTime      @default(now())
  vendor            VendorProfile @relation(fields: [vendorId], references: [id])
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum Status {
  ACTIVE
  BLOCKED
}
